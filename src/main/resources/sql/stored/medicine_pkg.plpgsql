CREATE SCHEMA IF NOT EXISTS medicine_pkg;

create or replace function medicine_pkg.getBrands()
returns setof brand as $$
begin
return query
select * from brand;
end;
$$ LANGUAGE plpgsql;

create or replace function medicine_pkg.findBrands(p_name varchar)
returns setof brand as $$
begin
return query
select * from brand
where LOWER(name) LIKE LOWER(CONCAT('%', p_name, '%'));
end;
$$ LANGUAGE plpgsql;

create or replace procedure medicine_pkg.createBrand(p_name varchar, p_error out varchar)
as $$
begin
insert into brand(name)
values (p_name);
exception
when unique_violation then
        p_error := concat('Бренд с именем ', p_name, ' уже существует');
when not_null_violation then
        p_error := 'Название бренда не может быть пустым';
end;
$$ LANGUAGE plpgsql;


create or replace function medicine_pkg.getAtcList()
returns setof atc_classification as $$
begin
return query
select * from atc_classification;
end;
$$ LANGUAGE plpgsql;

create or replace function medicine_pkg.findAtcCode(p_code varchar)
returns setof atc_classification as $$
begin
return query
select * from atc_classification
where LOWER(code) LIKE LOWER(CONCAT('%', p_code, '%'));
end;
$$ LANGUAGE plpgsql;

create or replace procedure medicine_pkg.createAtcCode(p_code varchar, p_description varchar, p_error out varchar)
as $$
begin
if p_code != '' and position(' ' in p_code) = 0 then
insert into atc_classification(code, description)
values (p_code, p_description);
else
p_error := 'В названии присутствуют пробелы!';
end if;
exception
when unique_violation then
        p_error := concat('АТХ-код ', p_code, ' уже существует');
when not_null_violation then
        p_error := 'Название бренда не может быть пустым';
end;
$$ LANGUAGE plpgsql;



