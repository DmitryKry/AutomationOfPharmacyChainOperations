CREATE OR REPLACE PROCEDURE medicine_pkg.create_medicine(
    OUT p_error VARCHAR,
    out id_medicine numeric(38,2),
    -- Основная информация
    p_name VARCHAR,
    p_unit_of_measure varchar,
    p_price numeric(38,2),
    p_international_name VARCHAR DEFAULT NULL,
    p_dosage_strength VARCHAR DEFAULT NULL,
    p_package_quantity INTEGER DEFAULT NULL,
    p_prescription_required BOOLEAN DEFAULT TRUE,

    -- Регистрационные данные
    p_registration_number VARCHAR DEFAULT NULL,
    p_registration_date DATE DEFAULT NULL,

    -- Условия хранения
    p_shelf_life_months INTEGER DEFAULT NULL,
    p_storage_temperature_min INTEGER DEFAULT NULL,
    p_storage_temperature_max INTEGER DEFAULT NULL,
    p_requires_refrigeration BOOLEAN DEFAULT FALSE,
    p_light_sensitive BOOLEAN DEFAULT FALSE,
    p_requires_dark_storage BOOLEAN DEFAULT FALSE,

    -- Статусные флаги
    p_is_active BOOLEAN DEFAULT TRUE,
    p_is_vital BOOLEAN DEFAULT FALSE,
    p_is_available BOOLEAN DEFAULT TRUE,


    -- Внешние ключи (ID из справочников)
    p_pharmacological_group_id NUMERIC DEFAULT NULL,
    p_therapeutic_group_id NUMERIC DEFAULT NULL,
    p_manufacturer_id NUMERIC DEFAULT NULL,
    p_country_id NUMERIC DEFAULT NULL,
    p_prescription_form_id NUMERIC DEFAULT NULL,
    p_dosage_form_id NUMERIC DEFAULT NULL,
    p_brand_id NUMERIC DEFAULT NULL,
    p_atc_id NUMERIC DEFAULT NULL,
    p_package_type_id NUMERIC DEFAULT NULL)
AS $$
BEGIN
    p_error := NULL;

    -- Валидация обязательных полей
    IF p_name IS NULL OR trim(p_name) = '' THEN
        p_error := 'Название препарата не может быть пустым';
        RETURN;
END IF;

    -- Вставка данных
INSERT INTO public.medicine (
    name,
    international_name,
    dosage_strength,
    package_quantity,
    prescription_required,
    registration_number,
    registration_date,
    shelf_life_months,
    storage_temperature_min,
    storage_temperature_max,
    requires_refrigeration,
    light_sensitive,
    requires_dark_storage,
    is_active,
    is_vital,
    is_available,
    is_deleted,
    pharmacological_group_id,
    therapeutic_group_id,
    manufacturer_id,
    country_id,
    prescription_form_id,
    dosage_form_id,
    brand_id,
    atc_id,
    package_type_id,
    unit_of_measure,
    price
) VALUES (
             p_name,
             p_international_name,
             p_dosage_strength,
             p_package_quantity,
             p_prescription_required,
             p_registration_number,
             p_registration_date,
             p_shelf_life_months,
             p_storage_temperature_min,
             p_storage_temperature_max,
             p_requires_refrigeration,
             p_light_sensitive,
             p_requires_dark_storage,
             p_is_active,
             p_is_vital,
             p_is_available,
             FALSE,
             p_pharmacological_group_id,
             p_therapeutic_group_id,
             p_manufacturer_id,
             p_country_id,
             p_prescription_form_id,
             p_dosage_form_id,
             p_brand_id,
             p_atc_id,
             p_package_type_id,
             p_unit_of_measure,
             p_price
         )
    RETURNING id INTO id_medicine;

EXCEPTION
    WHEN unique_violation THEN
        p_error := 'Препарат с таким названием или регистрационным номером уже существует';
WHEN foreign_key_violation THEN
        p_error := 'Один из внешних ключей ссылается на несуществующую запись в справочнике';
WHEN not_null_violation THEN
        p_error := 'Обязательное поле не может быть NULL';
WHEN OTHERS THEN
        p_error := concat('Ошибка при создании препарата: ', SQLERRM);
END;
$$ LANGUAGE plpgsql;


create or replace function medicine_pkg.getAllMedicines()
returns table (
       id numeric(38,2),
    name varchar,
    international_name varchar,
    dosage_strength varchar,
    price numeric(38,2),
    brandName varchar,
    countryName varchar,
    dosageFormName varchar,
    unit_of_measure varchar,
    package_quantity integer
)
 as $$
       begin
       return QUERY
        select m.id, m.name, m.international_name, m.dosage_strength, m.price, b.name as brandName, c.name as countryName,
               CASE
                   WHEN POSITION(' ' IN df.name) > 0
                       THEN SUBSTRING(df.name, 1, POSITION(' ' IN df.name) - 2)
                   WHEN POSITION(',' IN df.name) > 0
                       THEN SUBSTRING(df.name, 1, POSITION(',' IN df.name) - 2)
                   ELSE df.name
                   END as dosageFormName,
            m.unit_of_measure,
            m.package_quantity
        from medicine m
                 join brand b on b.id = m.brand_id
                 join country c on c.id = m.country_id
                 join dosage_form df on df.id = m.dosage_form_id;
end;
$$ language plpgsql;

create or replace function medicine_pkg.get_medicine(idMedicine numeric(38,2))
       returns table(
       id numeric(38,2),
       name character varying(200),
       international_name character varying(200),
       dosage_strength character varying(50),
       package_quantity integer,
       prescriptionRequiredWord varchar,
       registration_number character varying(50),
       registration_date date,
       shelf_life_months integer,
       storage_temperature_min integer,
       storage_temperature_max integer,
       requiresRefrigerationWord varchar,
       lightSensitiveWord varchar,
       requiresDarkStorageWord varchar,
       is_active boolean,
       is_vital boolean,
       is_available boolean,
       pharmacological_group_id numeric(38,2),
       pharmacological_group_name varchar,
       therapeutic_group_id numeric(38,2),
       therapeutic_group_name varchar,
       manufacturer_id numeric(38,2),
       manufacturer_name varchar,
       country_id numeric(38,2),
       countryName varchar,
       prescription_form_id numeric(38,2),
       prescription_form_name varchar,
       dosage_form_id numeric(38,2),
       dosageFormName varchar,
       brand_id numeric(38,2),
       brandName varchar,
       atc_id numeric(38,2),
       atc_code varchar,
       package_type_id numeric(38,2),
       package_type_name varchar,
       price numeric(38,2),
       unit_of_measure character varying(255)
       ) as $$
begin
return query
select
    m.id,
    m.name,
    m.international_name,
    m.dosage_strength,
    m.package_quantity,
    case when m.prescription_required = false
        then 'Нет'::varchar else 'Да'::varchar end prescriptionRequiredWord,
    m.registration_number,
    m.registration_date,
    m.shelf_life_months,
    m.storage_temperature_min,
    m.storage_temperature_max,
    case when m.requires_refrigeration = false
        then 'Нет'::varchar else 'Да'::varchar end requiresRefrigerationWord,
    case when m.light_sensitive = false
             then 'Нет'::varchar else 'Да'::varchar end lightSensitiveWord,
    case when m.requires_dark_storage = false
             then 'Нет'::varchar else 'Да'::varchar end requiresDarkStorageWord,
    m.is_active,
    m.is_vital,
    m.is_available,
    m.pharmacological_group_id,
    pg.name as pharmacological_group_name,
    m.therapeutic_group_id,
    tg.name as therapeutic_group_name,
    m.manufacturer_id,
    mf.name as manufacturer_name,
    m.country_id,
    c.name as countryName,
    m.prescription_form_id,
    pf.name as prescription_form_name,
    m.dosage_form_id,
    df.name as dosage_form_name,
    m.brand_id,
    b.name as brandName,
    m.atc_id,
    a.code as atc_code,
    m.package_type_id,
    pt.name as package_type_name,
    m.price,
    m.unit_of_measure
from medicine m
         join pharmacological_group pg on pg.id = m.pharmacological_group_id
         join therapeutic_group tg on tg.id = m.therapeutic_group_id
         join manufacturer mf on mf.id = m.manufacturer_id
         join country c on c.id = m.country_id
         join prescription_form pf on pf.id = m.prescription_form_id
         join dosage_form df on df.id = m.dosage_form_id
         join brand b on b.id = m.brand_id
         join atc_classification a on a.id = m.atc_id
         join type_packaging pt on pt.id = m.package_type_id
where m.id = idMedicine;
end;
$$ language plpgsql;


create or replace procedure medicine_pkg.set_photo_medicine(id_medicine numeric(38,2), url_photo varchar,
       p_error out varchar, med_id out numeric(38,2))
as $$
begin
    if exists (select 1 from photos where entity_type = 'M' and entity_id = id_medicine) then
        update photos
        set photo_path = url_photo, updated_at = CURRENT_TIMESTAMP
        where entity_id = id_medicine and entity_type = 'M';
        med_id := id_medicine;
    elsif id_medicine is not null then
        insert into photos (entity_id, entity_type, photo_path)
        values (id_medicine, 'M', url_photo)
        returning id into med_id;
    else
        insert into photos (entity_type, photo_path)
        values ('M', url_photo)
        returning id into med_id;
    end if;
EXCEPTION
    WHEN unique_violation THEN
        p_error := 'Фото с таким названием или регистрационным номером уже существует';
WHEN foreign_key_violation THEN
        p_error := 'Один из внешних ключей ссылается на несуществующую запись в справочнике';
WHEN not_null_violation THEN
        p_error := 'Обязательное поле не может быть NULL';
WHEN OTHERS THEN
        p_error := concat('Ошибка при создании фото: ', SQLERRM);
END;
$$ language plpgsql;

create or replace function medicine_pkg.get_photo_medicine(id_medicine numeric(38,2))
returns table (
    id numeric,
    entity_id numeric,
    entity_type varchar,
    photo_path varchar,
    file_name varchar
) as $$
begin
return query
select
    p.id, p.entity_id, p.entity_type::varchar, p.photo_path,
    p.file_name
from photos p
where p.entity_id = id_medicine and p.entity_type = 'M';
end;
$$ language plpgsql;

create or replace function medicine_pkg.get_photos_med()
returns table (
    id numeric,
    entity_id numeric,
    entity_type varchar,
    photo_path varchar
) as $$
       begin
       return query
select
    p.id, p.entity_id, p.entity_type::varchar, p.photo_path
from photos p
where p.entity_type = 'M';
end;
$$ language plpgsql;

CREATE OR REPLACE PROCEDURE medicine_pkg.update_medicine(
    OUT p_error VARCHAR,
    p_id NUMERIC,

    -- Основная информация
    p_name VARCHAR,
    p_unit_of_measure VARCHAR,
    p_price NUMERIC(38,2),
    p_international_name VARCHAR DEFAULT NULL,
    p_dosage_strength VARCHAR DEFAULT NULL,
    p_package_quantity INTEGER DEFAULT NULL,
    p_prescription_required BOOLEAN DEFAULT TRUE,

    -- Регистрационные данные
    p_registration_number VARCHAR DEFAULT NULL,
    p_registration_date DATE DEFAULT NULL,

    -- Условия хранения
    p_shelf_life_months INTEGER DEFAULT NULL,
    p_storage_temperature_min INTEGER DEFAULT NULL,
    p_storage_temperature_max INTEGER DEFAULT NULL,
    p_requires_refrigeration BOOLEAN DEFAULT FALSE,
    p_light_sensitive BOOLEAN DEFAULT FALSE,
    p_requires_dark_storage BOOLEAN DEFAULT FALSE,

    -- Статусные флаги
    p_is_active BOOLEAN DEFAULT TRUE,
    p_is_vital BOOLEAN DEFAULT FALSE,
    p_is_available BOOLEAN DEFAULT TRUE,

    -- Внешние ключи (ID из справочников)
    p_pharmacological_group_id NUMERIC DEFAULT NULL,
    p_therapeutic_group_id NUMERIC DEFAULT NULL,
    p_manufacturer_id NUMERIC DEFAULT NULL,
    p_country_id NUMERIC DEFAULT NULL,
    p_prescription_form_id NUMERIC DEFAULT NULL,
    p_dosage_form_id NUMERIC DEFAULT NULL,
    p_brand_id NUMERIC DEFAULT NULL,
    p_atc_id NUMERIC DEFAULT NULL,
    p_package_type_id NUMERIC DEFAULT NULL)
AS $$
BEGIN
    p_error := NULL;

    -- Валидация входных данных
    IF p_id IS NULL THEN
        p_error := 'Идентификатор препарата (ID) не может быть пустым';
        RETURN;
END IF;

    IF p_name IS NULL OR trim(p_name) = '' THEN
        p_error := 'Название препарата не может быть пустым';
        RETURN;
END IF;

    -- Обновление данных одной командой без лишних проверок
UPDATE public.medicine
SET
    name = p_name,
    international_name = p_international_name,
    dosage_strength = p_dosage_strength,
    package_quantity = p_package_quantity,
    prescription_required = p_prescription_required,
    registration_number = p_registration_number,
    registration_date = p_registration_date,
    shelf_life_months = p_shelf_life_months,
    storage_temperature_min = p_storage_temperature_min,
    storage_temperature_max = p_storage_temperature_max,
    requires_refrigeration = p_requires_refrigeration,
    light_sensitive = p_light_sensitive,
    requires_dark_storage = p_requires_dark_storage,
    is_active = p_is_active,
    is_vital = p_is_vital,
    is_available = p_is_available,
    pharmacological_group_id = p_pharmacological_group_id,
    therapeutic_group_id = p_therapeutic_group_id,
    manufacturer_id = p_manufacturer_id,
    country_id = p_country_id,
    prescription_form_id = p_prescription_form_id,
    dosage_form_id = p_dosage_form_id,
    brand_id = p_brand_id,
    atc_id = p_atc_id,
    package_type_id = p_package_type_id,
    unit_of_measure = p_unit_of_measure,
    price = p_price
WHERE id = p_id;

IF NOT FOUND THEN
        p_error := 'Препарат с указанным ID не найден в базе данных';
END IF;

EXCEPTION
    WHEN unique_violation THEN
        p_error := 'Препарат с таким названием или регистрационным номером уже существует';
WHEN foreign_key_violation THEN
        p_error := 'Один из внешних ключей ссылается на несуществующую запись в справочнике';
WHEN not_null_violation THEN
        p_error := 'Обязательное поле не может быть NULL';
WHEN OTHERS THEN
        p_error := concat('Ошибка при обновлении препарата: ', SQLERRM);
END;
$$ LANGUAGE plpgsql;


create or replace procedure medicine_pkg.delete_medicine(id_medicine numeric(38,2))
    as $$
       begin
       delete from medicine where id = id_medicine;
       delete from photos where photos.entity_id = id_medicine;
end;
$$ language plpgsql;

create or replace procedure medicine_pkg.update_photo(photo_id numeric(38,2), medicine_id numeric(38,2))
       as $$
begin
update photos
set entity_id = medicine_id
where id = photo_id;
end;
$$ language plpgsql;

