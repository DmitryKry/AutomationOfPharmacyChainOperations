create or replace procedure medicine_pkg.create_dosage_form(p_name varchar, p_is_solid boolean,
       p_is_liquid boolean, p_administration_route_id boolean, p_error out varchar)
as $$
begin
if p_name != '' then
insert into dosage_form(name, is_solid, is_liquid, administration_route_id)
values (p_name, p_is_solid, p_is_liquid, p_administration_route_id);
else
   p_error := 'Название справочника лекарственных форм не может быть пустым';
end if;
exception
when unique_violation then
        p_error := concat('Справочник лекарственных форм с названием ', p_name, ' уже существует');
when not_null_violation then
        p_error := 'Название справочника лекарственных форм не может быть пустым';
end;
$$ LANGUAGE plpgsql;


